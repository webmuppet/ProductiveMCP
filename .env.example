# Productive.io API Configuration
PRODUCTIVE_API_TOKEN=your_api_token_here
PRODUCTIVE_ORG_ID=your_org_id_here

# Sandbox Configuration (optional — for environment toggle)
# PRODUCTIVE_SANDBOX_API_TOKEN=your_sandbox_token_here
# PRODUCTIVE_SANDBOX_ORG_ID=your_sandbox_org_id_here
